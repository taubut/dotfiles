#!/bin/bash
# Mount 2ndPro NTFS drive

UUID="840048A400489F54"
MOUNT_POINT="/mnt/2ndPro"

# Check if already mounted anywhere
CURRENT_MOUNT=$(lsblk -o MOUNTPOINT -n /dev/disk/by-uuid/$UUID 2>/dev/null | grep -v '^$')
if [[ -n "$CURRENT_MOUNT" ]]; then
    echo "2ndPro is already mounted at $CURRENT_MOUNT"
    exit 0
fi

sudo mkdir -p "$MOUNT_POINT"
sudo mount -t ntfs-3g -o uid=1000,gid=1000,dmask=022,fmask=133 UUID=$UUID "$MOUNT_POINT"

if mountpoint -q "$MOUNT_POINT"; then
    echo "2ndPro mounted successfully at $MOUNT_POINT"
else
    echo "Failed to mount 2ndPro"
    exit 1
fi

# Mount Steam library image
STEAM_IMG="$MOUNT_POINT/steamlibrary.img"
STEAM_MOUNT="/mnt/steamlib"

if mountpoint -q "$STEAM_MOUNT"; then
    echo "Steam library already mounted at $STEAM_MOUNT"
else
    sudo mkdir -p "$STEAM_MOUNT"
    sudo mount -o loop "$STEAM_IMG" "$STEAM_MOUNT"
    sudo chown 1000:1000 "$STEAM_MOUNT"
    if mountpoint -q "$STEAM_MOUNT"; then
        echo "Steam library mounted at $STEAM_MOUNT"
    else
        echo "Failed to mount Steam library image"
        exit 1
    fi
fi
