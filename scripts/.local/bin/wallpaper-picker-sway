#!/bin/bash
# Wallpaper picker for sway — browse with nsxiv, apply via swaybg + wallust
WALLPAPER_DIR="${1:-$HOME/Pictures/Wallpapers}"

if [[ ! -d "$WALLPAPER_DIR" ]]; then
    echo "Wallpaper directory not found: $WALLPAPER_DIR"
    exit 1
fi

selected=$(nsxiv -t -o "$WALLPAPER_DIR" 2>/dev/null | head -1)
[[ -z "$selected" ]] && exit 0

echo "$selected" > ~/.cache/hypr-wallpaper

pkill swaybg 2>/dev/null
swaybg -o '*' -i "$selected" -m fill &
disown

wallust run "$selected"

pkill -SIGUSR2 waybar 2>/dev/null

# Generate sway colors include for borders/focus
get_color() { grep "^palette = $1=" ~/.config/ghostty/config | cut -d'=' -f3 | tr -d ' '; }
focused=$(get_color 2)
unfocused=$(get_color 8)
urgent=$(get_color 1)
fg=$(grep "^foreground" ~/.config/ghostty/config | cut -d'=' -f2 | tr -d ' ')

mkdir -p ~/.config/sway/conf.d
cat > ~/.config/sway/conf.d/wallust-colors.conf <<EOF
# Generated by wallpaper-picker-sway
client.focused          $focused $focused $fg       $focused $focused
client.focused_inactive $unfocused $unfocused $fg   $unfocused $unfocused
client.unfocused        $unfocused $unfocused $fg   $unfocused $unfocused
client.urgent           $urgent $urgent $fg         $urgent $urgent
EOF

swaymsg reload 2>/dev/null
